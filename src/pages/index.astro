---
import Analytics from "@vercel/analytics/astro";
import { getCollection } from "astro:content";
import BaremoApp from "../components/BaremoApp.tsx";
import repeatersData from "../data/repeaters.json";
import metaData from "../data/meta.json";
import { categoryTotalsFromSubscores } from "../lib/stats";
import "../styles/global.css";

const entries = await getCollection("baremo");

const rows = entries.map((e) => ({
  dni: e.data.dni,
  nombre: e.data.nombre,
  total: e.data.total,
  pdfPage: e.data.pdfPage,
  categories: categoryTotalsFromSubscores(e.data.subscores),
}));
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Baremo Maestros Primaria 2026 · Madrid</title>
  </head>
  <body class="bg-neutral-50 text-neutral-900 min-h-screen antialiased">
    <BaremoApp rows={rows} repeaters={repeatersData} meta={metaData} client:load />
    <Analytics />
  </body>
</html>
